+QString QCosmoNativeMacHost::eventText(ObjcId event) const
+{
+    ObjcId chars = msgId(event, "characters");
+    if (!chars)
+        return QString();
+    const char *utf8 = msgUtf8String(chars, "UTF8String");
+    return QString::fromUtf8(utf8 ? utf8 : "");
+}
+
+QString QCosmoNativeMacHost::pasteboardText() const
+{
+    ObjcClass pasteboardClass = cls("NSPasteboard");
+    if (!pasteboardClass)
+        return QString();
+
+    ObjcId pasteboard = msgId(reinterpret_cast<ObjcId>(pasteboardClass), "generalPasteboard");
+    if (!pasteboard)
+        return QString();
+
+    ObjcId text = msgIdId(pasteboard, "stringForType:", string("public.utf8-plain-text"));
+    if (!text)
+        text = msgIdId(pasteboard, "stringForType:", string("NSStringPboardType"));
+
+    const char *utf8 = text ? msgUtf8String(text, "UTF8String") : nullptr;
+    return QString::fromUtf8(utf8 ? utf8 : "");
+}
+
+int QCosmoNativeMacHost::qtKeyForEvent(ObjcId event, const QString &text) const
+{
+    switch (msgUShort(event, "keyCode")) {
+    case 36:
+        return Qt::Key_Return;
+    case 48:
+        return Qt::Key_Tab;
+    case 49:
+        return Qt::Key_Space;
+    case 51:
+        return Qt::Key_Backspace;
+    case 53:
+        return Qt::Key_Escape;
+    case 123:
+        return Qt::Key_Left;
+    case 124:
+        return Qt::Key_Right;
+    case 125:
+        return Qt::Key_Down;
+    case 126:
+        return Qt::Key_Up;
+    default:
+        return qtKeyFromLatin1(text);
+    }
+}
+
+Qt::KeyboardModifiers QCosmoNativeMacHost::qtModifiersForEvent(ObjcId event) const
+{
+    constexpr unsigned long shift = 1ul << 17;
+    constexpr unsigned long control = 1ul << 18;
+    constexpr unsigned long option = 1ul << 19;
+    constexpr unsigned long command = 1ul << 20;
+
+    const unsigned long flags = msgULong(event, "modifierFlags");
+    Qt::KeyboardModifiers modifiers = Qt::NoModifier;
+    if (flags & shift)
+        modifiers |= Qt::ShiftModifier;
+    if (flags & option)
+        modifiers |= Qt::AltModifier;
+    if (flags & command)
+        modifiers |= Qt::ControlModifier;
+    if (flags & control)
+        modifiers |= Qt::MetaModifier;
+    return modifiers;
+}
+
+QPointF QCosmoNativeMacHost::qtMousePosition(ObjcId event) const
+{
+    const NSPoint point = msgPoint(event, "locationInWindow");
+    return QPointF(point.x, m_size.height() - point.y);
+}
+
+void QCosmoNativeMacHost::translateEvent(ObjcId event, QCosmoNativeEventSink *sink)
+{
+    if (!event || !sink)
+        return;
+
+    const long type = msgLong(event, "type");
+    switch (type) {
+    case 1: // NSLeftMouseDown
+        m_buttons |= Qt::LeftButton;
+        sink->handleHostMouse(qtMousePosition(event), m_buttons, Qt::LeftButton,
+                              QEvent::MouseButtonPress);
+        break;
+    case 2: // NSLeftMouseUp
+        m_buttons &= ~Qt::LeftButton;
+        sink->handleHostMouse(qtMousePosition(event), m_buttons, Qt::LeftButton,
+                              QEvent::MouseButtonRelease);
+        break;
+    case 3: // NSRightMouseDown
+        m_buttons |= Qt::RightButton;
+        sink->handleHostMouse(qtMousePosition(event), m_buttons, Qt::RightButton,
+                              QEvent::MouseButtonPress);
+        break;
+    case 4: // NSRightMouseUp
+        m_buttons &= ~Qt::RightButton;
+        sink->handleHostMouse(qtMousePosition(event), m_buttons, Qt::RightButton,
+                              QEvent::MouseButtonRelease);
+        break;
+    case 5: // NSMouseMoved
+    case 6: // NSLeftMouseDragged
+    case 7: // NSRightMouseDragged
+    case 27: // NSOtherMouseDragged
+        sink->handleHostMouse(qtMousePosition(event), m_buttons, Qt::NoButton,
+                              QEvent::MouseMove);
+        break;
+    case 10: { // NSKeyDown
+        const QString text = eventText(event);
+        const int key = qtKeyForEvent(event, text);
+        const Qt::KeyboardModifiers modifiers = qtModifiersForEvent(event);
+        if ((modifiers & Qt::ControlModifier) && key == Qt::Key_V) {
+            const QString pastedText = pasteboardText();
+            if (!pastedText.isEmpty()) {
+                sink->handleHostKey(QEvent::KeyPress, Qt::Key_unknown, Qt::NoModifier,
+                                    pastedText);
+                sink->handleHostKey(QEvent::KeyRelease, Qt::Key_unknown, Qt::NoModifier,
+                                    QString());
+                break;
+            }
+        }
+        sink->handleHostKey(QEvent::KeyPress, key, modifiers, text);
+        break;
+    }
+    case 11: { // NSKeyUp
+        const QString text = eventText(event);
+        sink->handleHostKey(QEvent::KeyRelease, qtKeyForEvent(event, text),
+                            qtModifiersForEvent(event), text);
+        break;
+    }
+    case 22: { // NSScrollWheel
+        const double dy = msgDouble(event, "scrollingDeltaY");
+        const double dx = msgDouble(event, "scrollingDeltaX");
+        sink->handleHostWheel(qtMousePosition(event), QPoint(int(dx * 8), int(dy * 8)));
+        break;
+    }
+    default:
+        break;
+    }
+}
+
+void QCosmoNativeMacHost::pumpEvents(QCosmoNativeEventSink *sink)
+{
+    if (!m_window)
+        return;
+
+    for (;;) {
+        ObjcId event = nextEvent();
+        if (!event)
+            break;
+        translateEvent(event, sink);
+        msgVoidId(m_app, "sendEvent:", event);
+    }
+
+    msgVoid(m_app, "updateWindows");
+
+    if (!msgBool(m_window, "isVisible") && sink)
+        sink->handleHostClose();
+}
