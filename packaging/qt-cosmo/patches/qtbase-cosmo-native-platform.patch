+using namespace Qt::StringLiterals;
+
+template <typename T>
+static T cosmoLoadFunction(void *handle, const char *name)
+{
+    void *symbol = cosmo_dlsym(handle, name);
+    if (!symbol)
+        return nullptr;
+    return reinterpret_cast<T>(cosmo_dltramp(symbol));
+}
+
+static QString lastCosmoDlError(const char *prefix)
+{
+    const char *error = cosmo_dlerror();
+    return QString::fromLatin1("%1: %2").arg(QString::fromLatin1(prefix),
+                                             QString::fromLatin1(error ? error : "unknown"));
+}
+
+static int qtKeyFromLatin1(const QString &text)
+{
+    if (text.size() != 1)
+        return Qt::Key_unknown;
+
+    const QChar ch = text.at(0);
+    if (ch >= u'a' && ch <= u'z')
+        return Qt::Key_A + ch.unicode() - u'a';
+    if (ch >= u'A' && ch <= u'Z')
+        return Qt::Key_A + ch.unicode() - u'A';
+    if (ch >= u'0' && ch <= u'9')
+        return Qt::Key_0 + ch.unicode() - u'0';
+    if (ch == u' ')
+        return Qt::Key_Space;
+    return ch.unicode();
+}
+
+// -------------------------------------------------------------------------
+// macOS/AppKit host. This intentionally avoids all Apple SDK headers so it can
+// be built inside Cosmopolitan's libc namespace.
+
+typedef struct objc_object *ObjcId;
+typedef struct objc_class *ObjcClass;
+typedef struct objc_selector *ObjcSel;
+
+struct NSPoint {
+    double x;
+    double y;
+};
+
+struct NSSize {
+    double width;
+    double height;
+};
+
+struct NSRect {
+    NSPoint origin;
+    NSSize size;
+};
+
+class QCosmoNativeMacHost final : public QCosmoNativeHost
+{
+public:
+    bool initialize(const QSize &size, const QString &title) override;
+    void shutdown() override;
+    void pumpEvents(QCosmoNativeEventSink *sink) override;
+    void blit(const QImage &image, const QRegion &region) override;
+    QString errorString() const override { return m_error; }
+
+private:
+    template <typename T>
+    T loadObjc(const char *name)
+    {
+        void *symbol = cosmo_dlsym(m_objc, name);
+        if (!symbol) {
+            m_error = lastCosmoDlError(name);
+            return nullptr;
+        }
+        return reinterpret_cast<T>(cosmo_dltramp(symbol));
+    }
+
+    ObjcClass cls(const char *name) const { return m_objcGetClass(name); }
+    ObjcSel sel(const char *name) const { return m_selRegisterName(name); }
+    ObjcId string(const char *value) const;
+
+    ObjcId msgId(ObjcId receiver, const char *selector) const;
+    ObjcId msgIdId(ObjcId receiver, const char *selector, ObjcId arg) const;
+    ObjcId msgIdBool(ObjcId receiver, const char *selector, bool arg) const;
+    ObjcId msgIdInteger(ObjcId receiver, const char *selector, long arg) const;
+    ObjcId msgIdUnsignedLongLongId(ObjcId receiver, const char *selector, unsigned long long arg,
+                                   ObjcId idArg) const;
+    ObjcId msgIdRect(ObjcId receiver, const char *selector, NSRect rect) const;
+    ObjcId msgIdRectIntegerIntegerBool(ObjcId receiver, const char *selector, NSRect rect,
+                                       unsigned long style, unsigned long backing,
+                                       bool defer) const;
+    ObjcId msgIdSize(ObjcId receiver, const char *selector, NSSize size) const;
+    ObjcId msgBitmapRep(ObjcId receiver, unsigned char **planes, int width, int height,
+                        int bytesPerLine) const;
+    ObjcId nextEvent() const;
+
+    void msgVoid(ObjcId receiver, const char *selector) const;
+    void msgVoidId(ObjcId receiver, const char *selector, ObjcId arg) const;
+    void msgVoidBool(ObjcId receiver, const char *selector, bool arg) const;
+    void msgVoidInteger(ObjcId receiver, const char *selector, long arg) const;
+    long msgLong(ObjcId receiver, const char *selector) const;
+    bool msgBool(ObjcId receiver, const char *selector) const;
+    double msgDouble(ObjcId receiver, const char *selector) const;
+    unsigned short msgUShort(ObjcId receiver, const char *selector) const;
+    unsigned long msgULong(ObjcId receiver, const char *selector) const;
+    const char *msgUtf8String(ObjcId receiver, const char *selector) const;
+    NSPoint msgPoint(ObjcId receiver, const char *selector) const;
+
+    bool recreateImageView(const QImage &image);
+    void beginLatencyCriticalActivity();
+    void endLatencyCriticalActivity();
+    void translateEvent(ObjcId event, QCosmoNativeEventSink *sink);
+    QString eventText(ObjcId event) const;
+    QString pasteboardText() const;
+    int qtKeyForEvent(ObjcId event, const QString &text) const;
+    Qt::KeyboardModifiers qtModifiersForEvent(ObjcId event) const;
+    QPointF qtMousePosition(ObjcId event) const;
+
+    void *m_objc = nullptr;
+    void *m_appKit = nullptr;
+    ObjcClass (*m_objcGetClass)(const char *) = nullptr;
+    ObjcSel (*m_selRegisterName)(const char *) = nullptr;
+    void *m_msgSend = nullptr;
+    ObjcId m_pool = nullptr;
+    ObjcId m_app = nullptr;
+    ObjcId m_window = nullptr;
+    ObjcId m_imageView = nullptr;
+    ObjcId m_image = nullptr;
+    ObjcId m_bitmapRep = nullptr;
+    ObjcId m_processInfoActivity = nullptr;
+    QSize m_size;
+    const uchar *m_imageBits = nullptr;
+    int m_bytesPerLine = 0;
+    Qt::MouseButtons m_buttons = Qt::NoButton;
+    QString m_error;
+};
+
+bool QCosmoNativeMacHost::initialize(const QSize &size, const QString &title)
+{
+    m_objc = cosmo_dlopen("/usr/lib/libobjc.A.dylib", RTLD_NOW | RTLD_GLOBAL);
+    if (!m_objc) {
+        m_error = lastCosmoDlError("libobjc");
+        return false;
+    }
+
+    m_appKit = cosmo_dlopen("/System/Library/Frameworks/AppKit.framework/AppKit",
+                            RTLD_NOW | RTLD_GLOBAL);
+    if (!m_appKit) {
+        m_error = lastCosmoDlError("AppKit");
+        return false;
+    }
+
+    m_objcGetClass = loadObjc<ObjcClass (*)(const char *)>("objc_getClass");
+    m_selRegisterName = loadObjc<ObjcSel (*)(const char *)>("sel_registerName");
+    m_msgSend = loadObjc<void *>("objc_msgSend");
+    if (!m_objcGetClass || !m_selRegisterName || !m_msgSend)
+        return false;
+
+    ObjcClass poolClass = cls("NSAutoreleasePool");
+    ObjcClass appClass = cls("NSApplication");
+    ObjcClass windowClass = cls("NSWindow");
+    if (!poolClass || !appClass || !windowClass) {
+        m_error = "AppKit classes are unavailable"_L1;
+        return false;
+    }
+
+    m_pool = msgId(reinterpret_cast<ObjcId>(poolClass), "new");
+    m_app = msgId(reinterpret_cast<ObjcId>(appClass), "sharedApplication");
+    msgIdInteger(m_app, "setActivationPolicy:", 0);
+    msgVoid(m_app, "finishLaunching");
+
+    constexpr unsigned long titled = 1u << 0;
+    constexpr unsigned long closable = 1u << 1;
+    constexpr unsigned long miniaturizable = 1u << 2;
+    constexpr unsigned long buffered = 2;
+
+    NSRect frame = {{160, 160}, {double(size.width()), double(size.height())}};
+    ObjcId allocatedWindow = msgId(reinterpret_cast<ObjcId>(windowClass), "alloc");
+    m_window = msgIdRectIntegerIntegerBool(allocatedWindow,
+                                           "initWithContentRect:styleMask:backing:defer:",
+                                           frame,
+                                           titled | closable | miniaturizable,
+                                           buffered,
+                                           false);
+    if (!m_window) {
+        m_error = "NSWindow allocation failed"_L1;
+        return false;
+    }
+    const QByteArray titleUtf8 = title.toUtf8();
+    msgVoidId(m_window, "setTitle:", string(titleUtf8.constData()));
+    msgVoidBool(m_window, "setReleasedWhenClosed:", false);
+    msgVoidId(m_window, "makeKeyAndOrderFront:", nullptr);
+    msgVoid(m_window, "orderFrontRegardless");
+    msgVoidBool(m_app, "activateIgnoringOtherApps:", true);
+    beginLatencyCriticalActivity();
+
+    m_size = size;
+    return true;
+}
+
+void QCosmoNativeMacHost::shutdown()
+{
+    endLatencyCriticalActivity();
+
+    if (m_window)
+        msgVoid(m_window, "close");
+    if (m_imageView)
+        msgVoid(m_imageView, "release");
+    if (m_image)
+        msgVoid(m_image, "release");
+    if (m_bitmapRep)
+        msgVoid(m_bitmapRep, "release");
+    if (m_pool)
+        msgVoid(m_pool, "drain");
+    m_window = nullptr;
+    m_imageView = nullptr;
+    m_image = nullptr;
+    m_bitmapRep = nullptr;
+    m_pool = nullptr;
+}
