+
+bool QCosmoNativeX11Host::connectDisplay(const QByteArray &display)
+{
+    const QByteArray effectiveDisplay = display.isEmpty() ? QByteArray(":0") : display;
+    const int colon = effectiveDisplay.indexOf(':');
+    if (colon < 0) {
+        m_error = "DISPLAY is not an X11 display string"_L1;
+        return false;
+    }
+
+    const QByteArray host = effectiveDisplay.left(colon);
+    const int displayNumber = x11DisplayNumber(effectiveDisplay).toInt();
+    if (host.isEmpty() || host == "unix") {
+        m_fd = ::socket(AF_UNIX, SOCK_STREAM, 0);
+        if (m_fd < 0) {
+            m_error = QString::fromLatin1("socket(AF_UNIX) failed: %1").arg(strerror(errno));
+            return false;
+        }
+
+        sockaddr_un address = {};
+        address.sun_family = AF_UNIX;
+        const QByteArray path = QByteArray("/tmp/.X11-unix/X") + QByteArray::number(displayNumber);
+        qstrncpy(address.sun_path, path.constData(), sizeof(address.sun_path));
+        if (::connect(m_fd, reinterpret_cast<sockaddr *>(&address), sizeof(address)) != 0) {
+            m_error = QString::fromLatin1("connect(%1) failed: %2")
+                              .arg(QString::fromLocal8Bit(path), QString::fromLatin1(strerror(errno)));
+            ::close(m_fd);
+            m_fd = -1;
+            return false;
+        }
+        return true;
+    }
+
+    if (host != "localhost" && host != "127.0.0.1") {
+        m_error = QString::fromLatin1("unsupported X11 DISPLAY host: %1")
+                          .arg(QString::fromLocal8Bit(host));
+        return false;
+    }
+
+    m_fd = ::socket(AF_INET, SOCK_STREAM, 0);
+    if (m_fd < 0) {
+        m_error = QString::fromLatin1("socket(AF_INET) failed: %1").arg(strerror(errno));
+        return false;
+    }
+
+    sockaddr_in address = {};
+    address.sin_family = AF_INET;
+    address.sin_port = htons(quint16(6000 + displayNumber));
+    address.sin_addr.s_addr = htonl(0x7f000001u);
+    if (::connect(m_fd, reinterpret_cast<sockaddr *>(&address), sizeof(address)) != 0) {
+        m_error = QString::fromLatin1("connect(localhost:%1) failed: %2")
+                          .arg(6000 + displayNumber)
+                          .arg(QString::fromLatin1(strerror(errno)));
+        ::close(m_fd);
+        m_fd = -1;
+        return false;
+    }
+    return true;
+}
+
+bool QCosmoNativeX11Host::writeAll(const QByteArray &bytes)
+{
+    const char *data = bytes.constData();
+    qsizetype remaining = bytes.size();
+    while (remaining > 0) {
+        const ssize_t written = ::write(m_fd, data, size_t(remaining));
+        if (written < 0) {
+            if (errno == EINTR)
+                continue;
+            m_error = QString::fromLatin1("X11 write failed: %1").arg(strerror(errno));
+            return false;
+        }
+        data += written;
+        remaining -= written;
+    }
+    return true;
+}
+
+bool QCosmoNativeX11Host::readFull(char *data, qsizetype size)
+{
+    qsizetype remaining = size;
+    while (remaining > 0) {
+        const ssize_t got = ::read(m_fd, data, size_t(remaining));
+        if (got < 0) {
+            if (errno == EINTR)
+                continue;
+            m_error = QString::fromLatin1("X11 read failed: %1").arg(strerror(errno));
+            return false;
+        }
+        if (got == 0) {
+            m_error = "X11 server closed the connection"_L1;
+            return false;
+        }
+        data += got;
+        remaining -= got;
+    }
+    return true;
+}
+
+bool QCosmoNativeX11Host::readSetup()
+{
+    char header[8] = {};
+    if (!readFull(header, sizeof(header)))
+        return false;
+
+    const uchar *h = reinterpret_cast<const uchar *>(header);
+    const quint16 extraLength = x11Le16(h + 6);
+    QByteArray payload(extraLength * 4, Qt::Uninitialized);
+    if (!payload.isEmpty() && !readFull(payload.data(), payload.size()))
+        return false;
+
+    if (h[0] != 1) {
+        const int reasonLength = h[1];
+        m_error = QString::fromLatin1("X11 setup failed: %1")
+                          .arg(QString::fromLatin1(payload.constData(),
+                                                   qMin(reasonLength, payload.size())));
+        return false;
+    }
+
+    if (payload.size() < 40) {
+        m_error = "X11 setup reply is truncated"_L1;
+        return false;
+    }
+
+    const uchar *p = reinterpret_cast<const uchar *>(payload.constData());
+    m_resourceBase = x11Le32(p + 4);
+    m_resourceMask = x11Le32(p + 8);
+    m_maxRequestLength = x11Le16(p + 18);
+    const quint16 vendorLength = x11Le16(p + 16);
+    const quint8 rootsLength = p[20];
+    const quint8 pixmapFormatsLength = p[21];
+    m_minKeycode = p[26];
+    const quint8 maxKeycode = p[27];
+
+    const int pixmapOffset = 32 + x11Pad4(vendorLength);
+    const int screensOffset = pixmapOffset + pixmapFormatsLength * 8;
+    if (rootsLength == 0 || payload.size() < screensOffset + 40) {
+        m_error = "X11 setup reply has no screen"_L1;
+        return false;
+    }
+
+    const uchar *screen = p + screensOffset;
+    m_root = x11Le32(screen);
+    m_whitePixel = x11Le32(screen + 12);
+    m_blackPixel = x11Le32(screen + 16);
+    m_rootVisual = x11Le32(screen + 32);
+    m_depth = screen[38];
+    m_bitsPerPixel = 32;
+    for (int i = 0; i < pixmapFormatsLength; ++i) {
+        const uchar *format = p + pixmapOffset + i * 8;
+        if (format[0] == m_depth) {
+            m_bitsPerPixel = format[1];
+            break;
+        }
+    }
+
+    if (m_bitsPerPixel != 32) {
+        m_error = QString::fromLatin1("unsupported X11 framebuffer depth %1/%2")
+                          .arg(m_depth)
+                          .arg(m_bitsPerPixel);
+        return false;
+    }
+
+    m_keysyms.reserve(int(maxKeycode) - int(m_minKeycode) + 1);
+    return true;
+}
+
+bool QCosmoNativeX11Host::queryKeyboardMapping()
+{
+    if (m_minKeycode == 0)
+        return true;
+
+    const quint8 count = 248;
+    QByteArray request;
+    request.reserve(8);
+    x11Append8(&request, 101); // GetKeyboardMapping
+    x11Append8(&request, m_minKeycode);
+    x11Append16(&request, 2);
+    x11Append8(&request, count);
+    x11Append8(&request, 0);
+    x11Append16(&request, 0);
+    if (!writeAll(request))
+        return false;
+
+    char header[32] = {};
+    if (!readFull(header, sizeof(header)))
+        return false;
+
+    const uchar *h = reinterpret_cast<const uchar *>(header);
+    if (h[0] != 1)
+        return true;
+
+    m_keysymsPerKeycode = h[1];
+    const quint32 extraLength = x11Le32(h + 4);
+    QByteArray data(extraLength * 4, Qt::Uninitialized);
+    if (!data.isEmpty() && !readFull(data.data(), data.size()))
+        return false;
+
+    const int symbolCount = data.size() / 4;
+    m_keysyms.resize(symbolCount);
+    const uchar *p = reinterpret_cast<const uchar *>(data.constData());
+    for (int i = 0; i < symbolCount; ++i)
+        m_keysyms[i] = x11Le32(p + i * 4);
+    return true;
+}
+
+quint32 QCosmoNativeX11Host::allocateResource()
+{
+    const quint32 id = m_resourceBase | (m_resourceCounter & m_resourceMask);
+    ++m_resourceCounter;
+    return id;
+}
+
+bool QCosmoNativeX11Host::createWindow(const QSize &size, const QString &title)
+{
+    m_window = allocateResource();
+    m_gc = allocateResource();
+
+    constexpr quint32 keyPressMask = 1u << 0;
+    constexpr quint32 keyReleaseMask = 1u << 1;
+    constexpr quint32 buttonPressMask = 1u << 2;
+    constexpr quint32 buttonReleaseMask = 1u << 3;
+    constexpr quint32 pointerMotionMask = 1u << 6;
+    constexpr quint32 exposureMask = 1u << 15;
+    constexpr quint32 structureNotifyMask = 1u << 17;
+    const quint32 eventMask = keyPressMask | keyReleaseMask | buttonPressMask | buttonReleaseMask
+            | pointerMotionMask | exposureMask | structureNotifyMask;
+
+    QByteArray create;
+    create.reserve(40);
+    x11Append8(&create, 1); // CreateWindow
+    x11Append8(&create, 0); // CopyFromParent depth
+    x11Append16(&create, 10);
+    x11Append32(&create, m_window);
+    x11Append32(&create, m_root);
+    x11AppendS16(&create, 80);
+    x11AppendS16(&create, 80);
+    x11Append16(&create, quint16(size.width()));
+    x11Append16(&create, quint16(size.height()));
+    x11Append16(&create, 0);
+    x11Append16(&create, 1); // InputOutput
+    x11Append32(&create, 0); // CopyFromParent visual
+    x11Append32(&create, (1u << 1) | (1u << 11)); // CWBackPixel | CWEventMask
+    x11Append32(&create, m_blackPixel);
+    x11Append32(&create, eventMask);
+    if (!writeAll(create))
+        return false;
+
+    const QByteArray titleUtf8 = title.toUtf8();
+    QByteArray property;
+    const int propertyPayload = x11Pad4(titleUtf8.size());
+    property.reserve(24 + propertyPayload);
+    x11Append8(&property, 18); // ChangeProperty
+    x11Append8(&property, 0); // Replace
+    x11Append16(&property, quint16((24 + propertyPayload) / 4));
+    x11Append32(&property, m_window);
+    x11Append32(&property, 39); // WM_NAME
+    x11Append32(&property, 31); // STRING
+    x11Append8(&property, 8);
+    x11Append8(&property, 0);
+    x11Append16(&property, 0);
+    x11Append32(&property, quint32(titleUtf8.size()));
+    x11AppendPadded(&property, titleUtf8);
+    if (!writeAll(property))
+        return false;
+
+    QByteArray gc;
+    gc.reserve(24);
+    x11Append8(&gc, 55); // CreateGC
+    x11Append8(&gc, 0);
+    x11Append16(&gc, 6);
+    x11Append32(&gc, m_gc);
+    x11Append32(&gc, m_window);
+    x11Append32(&gc, (1u << 2) | (1u << 3)); // foreground | background
+    x11Append32(&gc, m_whitePixel);
+    x11Append32(&gc, m_blackPixel);
+    if (!writeAll(gc))
+        return false;
+
+    QByteArray map;
+    x11Append8(&map, 8); // MapWindow
+    x11Append8(&map, 0);
+    x11Append16(&map, 2);
+    x11Append32(&map, m_window);
+    if (!writeAll(map))
+        return false;
+
+    m_size = size;
+    return true;
+}
+
+bool QCosmoNativeX11Host::initialize(const QSize &size, const QString &title)
+{
+    const QByteArray display = qgetenv("DISPLAY").isEmpty() ? QByteArray(":0") : qgetenv("DISPLAY");
+    if (!connectDisplay(display))
+        return false;
+
+    const X11AuthCookie auth = x11ReadAuthCookie(display);
+    QByteArray setup;
+    setup.reserve(12 + x11Pad4(auth.name.size()) + x11Pad4(auth.data.size()));
+    x11Append8(&setup, 'l');
+    x11Append8(&setup, 0);
+    x11Append16(&setup, 11);
+    x11Append16(&setup, 0);
+    x11Append16(&setup, quint16(auth.name.size()));
+    x11Append16(&setup, quint16(auth.data.size()));
+    x11Append16(&setup, 0);
+    x11AppendPadded(&setup, auth.name);
+    x11AppendPadded(&setup, auth.data);
+    if (!writeAll(setup) || !readSetup() || !queryKeyboardMapping()
+        || !createWindow(size, title)) {
+        shutdown();
+        return false;
+    }
+
+    const int flags = fcntl(m_fd, F_GETFL, 0);
+    if (flags >= 0)
+        fcntl(m_fd, F_SETFL, flags | O_NONBLOCK);
+    return true;
+}
+
+void QCosmoNativeX11Host::sendDestroy(quint32 resource)
+{
+    if (m_fd < 0 || !resource)
+        return;
+    QByteArray request;
+    x11Append8(&request, 4); // DestroyWindow
+    x11Append8(&request, 0);
+    x11Append16(&request, 2);
+    x11Append32(&request, resource);
+    writeAll(request);
+}
+
+void QCosmoNativeX11Host::shutdown()
+{
+    if (m_fd >= 0) {
+        sendDestroy(m_window);
+        ::close(m_fd);
+    }
+    m_fd = -1;
+    m_window = 0;
+    m_gc = 0;
+}
+
+void QCosmoNativeX11Host::blit(const QImage &image, const QRegion &region)
+{
+    Q_UNUSED(region);
+    if (m_fd < 0 || !m_window || image.isNull())
+        return;
+
+    QImage converted;
+    const QImage *source = &image;
+    if (image.format() != QImage::Format_RGB32 && image.format() != QImage::Format_ARGB32
+        && image.format() != QImage::Format_ARGB32_Premultiplied) {
+        converted = image.convertToFormat(QImage::Format_RGB32);
+        source = &converted;
+    }
+
+    const int headerBytes = 24;
+    const int maxRequestBytes = qMax<int>(4096, int(m_maxRequestLength) * 4);
+    const int maxPayloadBytes = qMax<int>(source->bytesPerLine(), maxRequestBytes - headerBytes);
+    const int rowsPerRequest = qMax(1, maxPayloadBytes / source->bytesPerLine());
+    for (int y = 0; y < source->height(); y += rowsPerRequest) {
+        const int rows = qMin(rowsPerRequest, source->height() - y);
+        const int payloadBytes = source->bytesPerLine() * rows;
+        QByteArray request;
+        request.reserve(headerBytes + x11Pad4(payloadBytes));
+        x11Append8(&request, 72); // PutImage
+        x11Append8(&request, 2); // ZPixmap
+        x11Append16(&request, quint16((headerBytes + x11Pad4(payloadBytes)) / 4));
+        x11Append32(&request, m_window);
+        x11Append32(&request, m_gc);
+        x11Append16(&request, quint16(source->width()));
+        x11Append16(&request, quint16(rows));
+        x11AppendS16(&request, 0);
+        x11AppendS16(&request, qint16(y));
+        x11Append8(&request, 0);
+        x11Append8(&request, m_depth);
+        x11Append16(&request, 0);
+        request.append(reinterpret_cast<const char *>(source->constScanLine(y)), payloadBytes);
+        while (request.size() % 4)
+            request.append('\0');
+        if (!writeAll(request))
+            return;
+    }
+}
+
+Qt::KeyboardModifiers QCosmoNativeX11Host::modifiersFromState(quint16 state) const
+{
+    Qt::KeyboardModifiers modifiers = Qt::NoModifier;
+    if (state & 0x01)
+        modifiers |= Qt::ShiftModifier;
+    if (state & 0x04)
+        modifiers |= Qt::ControlModifier;
+    if (state & 0x08)
+        modifiers |= Qt::AltModifier;
+    if (state & 0x40)
+        modifiers |= Qt::MetaModifier;
+    return modifiers;
+}
+
+quint32 QCosmoNativeX11Host::keysymForKeycode(quint8 keycode, bool shifted) const
+{
+    if (!m_keysymsPerKeycode || keycode < m_minKeycode)
+        return 0;
+    const int row = int(keycode) - int(m_minKeycode);
+    const int base = row * int(m_keysymsPerKeycode);
+    if (base < 0 || base >= m_keysyms.size())
+        return 0;
+    if (shifted && m_keysymsPerKeycode > 1 && base + 1 < m_keysyms.size()
+        && m_keysyms.at(base + 1))
+        return m_keysyms.at(base + 1);
+    return m_keysyms.at(base);
+}
+
+int QCosmoNativeX11Host::qtKeyFromKeysym(quint32 keysym) const
+{
+    switch (keysym) {
+    case 0xff08:
+        return Qt::Key_Backspace;
+    case 0xff09:
+        return Qt::Key_Tab;
+    case 0xff0d:
+        return Qt::Key_Return;
+    case 0xff1b:
+        return Qt::Key_Escape;
+    case 0xff51:
+        return Qt::Key_Left;
+    case 0xff52:
+        return Qt::Key_Up;
+    case 0xff53:
+        return Qt::Key_Right;
+    case 0xff54:
+        return Qt::Key_Down;
+    default:
+        break;
+    }
+    if (keysym >= 'a' && keysym <= 'z')
+        return Qt::Key_A + int(keysym - 'a');
+    if (keysym >= 'A' && keysym <= 'Z')
+        return Qt::Key_A + int(keysym - 'A');
+    if (keysym >= '0' && keysym <= '9')
+        return Qt::Key_0 + int(keysym - '0');
+    if (keysym == ' ')
+        return Qt::Key_Space;
+    return keysym >= 0x20 && keysym <= 0x7e ? int(keysym) : Qt::Key_unknown;
+}
+
+void QCosmoNativeX11Host::translateButton(quint8 button, qint16 x, qint16 y, bool pressed,
+                                          QCosmoNativeEventSink *sink)
+{
+    if (!sink)
+        return;
+
+    if (button == 4 || button == 5) {
+        sink->handleHostWheel(QPointF(x, y), QPoint(0, button == 4 ? 120 : -120));
+        return;
+    }
+
+    Qt::MouseButton qtButton = Qt::NoButton;
+    if (button == 1)
+        qtButton = Qt::LeftButton;
+    else if (button == 2)
+        qtButton = Qt::MiddleButton;
+    else if (button == 3)
+        qtButton = Qt::RightButton;
+
+    if (pressed)
+        m_buttons |= qtButton;
+    else
+        m_buttons &= ~qtButton;
+    sink->handleHostMouse(QPointF(x, y), m_buttons, qtButton,
+                          pressed ? QEvent::MouseButtonPress : QEvent::MouseButtonRelease);
+}
+
+void QCosmoNativeX11Host::translateKey(quint8 keycode, quint16 state, QEvent::Type type,
+                                       QCosmoNativeEventSink *sink)
+{
+    if (!sink)
+        return;
+
+    const bool shifted = state & 0x01;
+    const quint32 keysym = keysymForKeycode(keycode, shifted);
+    QString text;
+    if (keysym >= 0x20 && keysym <= 0x7e)
+        text = QString(QChar(ushort(keysym)));
+    sink->handleHostKey(type, qtKeyFromKeysym(keysym), modifiersFromState(state), text);
+}
+
+void QCosmoNativeX11Host::translateEvent(const uchar *event, QCosmoNativeEventSink *sink)
+{
+    const quint8 type = event[0] & 0x7f;
+    const quint8 detail = event[1];
+    switch (type) {
+    case 2: // KeyPress
+        translateKey(detail, x11Le16(event + 28), QEvent::KeyPress, sink);
+        break;
+    case 3: // KeyRelease
+        translateKey(detail, x11Le16(event + 28), QEvent::KeyRelease, sink);
+        break;
+    case 4: // ButtonPress
+        translateButton(detail, x11LeS16(event + 24), x11LeS16(event + 26), true, sink);
+        break;
+    case 5: // ButtonRelease
+        translateButton(detail, x11LeS16(event + 24), x11LeS16(event + 26), false, sink);
+        break;
+    case 6: // MotionNotify
+        if (sink)
+            sink->handleHostMouse(QPointF(x11LeS16(event + 24), x11LeS16(event + 26)),
+                                  m_buttons, Qt::NoButton, QEvent::MouseMove);
+        break;
+    case 17: // DestroyNotify
+        if (sink)
+            sink->handleHostClose();
+        break;
+    case 22: { // ConfigureNotify
+        const QSize size(x11Le16(event + 20), x11Le16(event + 22));
+        if (sink && size.isValid() && size != m_size) {
+            m_size = size;
+            sink->handleHostResize(size);
+        }
+        break;
+    }
+    default:
+        break;
+    }
+}
+
+void QCosmoNativeX11Host::pumpEvents(QCosmoNativeEventSink *sink)
+{
+    if (m_fd < 0)
+        return;
+
+    char buffer[4096];
+    for (;;) {
+        const ssize_t got = ::read(m_fd, buffer, sizeof(buffer));
+        if (got < 0) {
+            if (errno == EINTR)
+                continue;
+            if (errno == EAGAIN || errno == EWOULDBLOCK)
+                break;
+            m_error = QString::fromLatin1("X11 event read failed: %1").arg(strerror(errno));
+            if (sink)
+                sink->handleHostClose();
+            return;
+        }
+        if (got == 0) {
+            if (sink)
+                sink->handleHostClose();
+            return;
+        }
+        m_eventBuffer.append(buffer, got);
+    }
+
+    while (m_eventBuffer.size() >= 32) {
+        translateEvent(reinterpret_cast<const uchar *>(m_eventBuffer.constData()), sink);
+        m_eventBuffer.remove(0, 32);
+    }
+}
+
+} // namespace
+
+QCosmoNativeHost *QCosmoNativeHost::create()
+{
+    if (IsXnu())
+        return new QCosmoNativeMacHost;
+    if (IsWindows())
+        return new QCosmoNativeWindowsHost;
+    if (IsLinux())
+        return new QCosmoNativeX11Host;
+
+    return nullptr;
+}
+
+QT_END_NAMESPACE
