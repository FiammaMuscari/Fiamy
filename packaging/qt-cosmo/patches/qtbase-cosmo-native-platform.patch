+#ifndef QCOSMONATIVEHOST_H
+#define QCOSMONATIVEHOST_H
+
+#include <QtCore/QEvent>
+#include <QtCore/QPoint>
+#include <QtCore/QScopedPointer>
+#include <QtCore/QString>
+#include <QtCore/Qt>
+#include <QtGui/QImage>
