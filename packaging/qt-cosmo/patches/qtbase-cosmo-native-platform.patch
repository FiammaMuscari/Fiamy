+bool QCosmoNativeMacHost::recreateImageView(const QImage &image)
+{
+    if (m_bitmapRep)
+        msgVoid(m_bitmapRep, "release");
+    if (m_image)
+        msgVoid(m_image, "release");
+
+    ObjcClass bitmapClass = cls("NSBitmapImageRep");
+    ObjcClass imageClass = cls("NSImage");
+    ObjcClass imageViewClass = cls("NSImageView");
+    if (!bitmapClass || !imageClass || !imageViewClass) {
+        m_error = "AppKit image classes are unavailable"_L1;
+        return false;
+    }
+
+    unsigned char *planes[5] = { const_cast<unsigned char *>(image.bits()), nullptr, nullptr,
+                                 nullptr, nullptr };
+    ObjcId bitmap = msgId(reinterpret_cast<ObjcId>(bitmapClass), "alloc");
+    m_bitmapRep = msgBitmapRep(bitmap, planes, image.width(), image.height(), image.bytesPerLine());
+
+    ObjcId allocatedImage = msgId(reinterpret_cast<ObjcId>(imageClass), "alloc");
+    m_image = msgIdSize(allocatedImage, "initWithSize:",
+                        NSSize{double(image.width()), double(image.height())});
+    msgVoidId(m_image, "addRepresentation:", m_bitmapRep);
+
+    if (!m_imageView) {
+        ObjcId allocatedView = msgId(reinterpret_cast<ObjcId>(imageViewClass), "alloc");
+        m_imageView = msgIdRect(allocatedView, "initWithFrame:",
+                                NSRect{{0, 0},
+                                       {double(image.width()), double(image.height())}});
+        if (!m_imageView) {
+            m_error = "NSImageView allocation failed"_L1;
+            return false;
+        }
+        msgVoidInteger(m_imageView, "setImageScaling:", 3);
+        msgVoidId(m_window, "setContentView:", m_imageView);
+    }
+
+    msgVoidId(m_imageView, "setImage:", m_image);
+    m_imageBits = image.bits();
+    m_bytesPerLine = image.bytesPerLine();
+    m_size = image.size();
+    return true;
+}
+
+void QCosmoNativeMacHost::beginLatencyCriticalActivity()
+{
+    ObjcClass processInfoClass = cls("NSProcessInfo");
+    if (!processInfoClass)
+        return;
+
+    ObjcId processInfo = msgId(reinterpret_cast<ObjcId>(processInfoClass), "processInfo");
+    if (!processInfo)
+        return;
+
+    constexpr unsigned long long idleSystemSleepDisabled = 1ULL << 20;
+    constexpr unsigned long long userInitiated =
+            0x00FFFFFFULL | idleSystemSleepDisabled;
+    constexpr unsigned long long userInitiatedAllowingIdleSystemSleep =
+            userInitiated & ~idleSystemSleepDisabled;
+    constexpr unsigned long long latencyCritical = 0xFF00000000ULL;
+
+    m_processInfoActivity = msgIdUnsignedLongLongId(
+            processInfo, "beginActivityWithOptions:reason:",
+            userInitiatedAllowingIdleSystemSleep | latencyCritical,
+            string("Fiamy audio playback"));
+}
+
+void QCosmoNativeMacHost::endLatencyCriticalActivity()
+{
+    if (!m_processInfoActivity)
+        return;
+
+    ObjcClass processInfoClass = cls("NSProcessInfo");
+    ObjcId processInfo =
+            processInfoClass ? msgId(reinterpret_cast<ObjcId>(processInfoClass), "processInfo")
+                             : nullptr;
+    if (processInfo)
+        msgVoidId(processInfo, "endActivity:", m_processInfoActivity);
+    m_processInfoActivity = nullptr;
+}
+
+void QCosmoNativeMacHost::blit(const QImage &image, const QRegion &region)
+{
+    Q_UNUSED(region);
+
+    if (!m_window)
+        return;
+
+    // NSImageView may keep drawing the cached NSImage contents even when the
+    // backing QImage memory changes. Rebuild the representation for each Qt
+    // framebuffer blit so the native window presents the current scene, not a
+    // stale snapshot that only grabWindow() can see.
+    if (!recreateImageView(image))
+        return;
+
+    msgVoidBool(m_imageView, "setNeedsDisplay:", true);
+    msgVoid(m_imageView, "displayIfNeeded");
+    msgVoid(m_window, "displayIfNeeded");
+    msgVoid(m_app, "updateWindows");
+}
