+
+QT_BEGIN_NAMESPACE
+
+class QCosmoNativeEventSink
+{
+public:
+    virtual ~QCosmoNativeEventSink() = default;
+
+    virtual void handleHostClose() = 0;
+    virtual void handleHostMouse(const QPointF &position, Qt::MouseButtons buttons,
+                                 Qt::MouseButton changedButton, QEvent::Type type) = 0;
+    virtual void handleHostWheel(const QPointF &position, const QPoint &angleDelta) = 0;
+    virtual void handleHostKey(QEvent::Type type, int key, Qt::KeyboardModifiers modifiers,
+                               const QString &text) = 0;
+    virtual void handleHostResize(const QSize &size) = 0;
+};
+
+class QCosmoNativeHost
+{
+public:
+    virtual ~QCosmoNativeHost() = default;
+
+    virtual bool initialize(const QSize &size, const QString &title) = 0;
+    virtual void shutdown() = 0;
+    virtual void pumpEvents(QCosmoNativeEventSink *sink) = 0;
+    virtual void blit(const QImage &image, const QRegion &region) = 0;
+    virtual QString errorString() const = 0;
+
+    static QCosmoNativeHost *create();
+};
