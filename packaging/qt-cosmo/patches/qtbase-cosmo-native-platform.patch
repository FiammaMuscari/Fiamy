+ObjcId QCosmoNativeMacHost::msgBitmapRep(ObjcId receiver, unsigned char **planes, int width,
+                                        int height, int bytesPerLine) const
+{
+    typedef ObjcId (*Msg)(ObjcId, ObjcSel, unsigned char **, long, long, long, long, bool,
+                          bool, ObjcId, unsigned long, long, long);
