+class QCosmoNativeWindowsHost final : public QCosmoNativeHost
+{
+public:
+    bool initialize(const QSize &size, const QString &title) override;
+    void shutdown() override;
+    void pumpEvents(QCosmoNativeEventSink *sink) override;
+    void blit(const QImage &image, const QRegion &region) override;
+    QString errorString() const override { return m_error; }
+
+    int64_t wndProc(int64_t hwnd, uint32_t message, uint64_t wParam, int64_t lParam);
+
+private:
+    struct PendingEvent {
+        enum Kind { Close, Mouse, Wheel, Key, Resize } kind = Close;
+        QPointF position;
+        QSize size;
+        Qt::MouseButtons buttons = Qt::NoButton;
+        Qt::MouseButton changedButton = Qt::NoButton;
+        QEvent::Type eventType = QEvent::None;
+        QPoint angleDelta;
+        int key = Qt::Key_unknown;
+        Qt::KeyboardModifiers modifiers = Qt::NoModifier;
+        QString text;
+    };
+
+    template <typename T>
+    T loadNtFunction(int64_t library, const char *name)
+    {
+        void *symbol = GetProcAddress(library, name);
+        if (!symbol)
+            m_error = QString::fromLatin1("GetProcAddress failed for %1").arg(name);
+        return reinterpret_cast<T>(symbol);
+    }
+
+    void enqueueMouse(uint32_t message, int64_t lParam);
+    void enqueueWheel(uint64_t wParam, int64_t lParam);
+    void enqueueKey(uint32_t message, uint64_t wParam);
+    void enqueueResize(int64_t lParam);
+
+    typedef int64_t(QCOSMO_MSABI *GetDCFn)(int64_t);
+    typedef int32_t(QCOSMO_MSABI *ReleaseDCFn)(int64_t, int64_t);
+    typedef int32_t(QCOSMO_MSABI *StretchDIBitsFn)(int64_t, int, int, int, int, int, int, int,
+                                                   int, const void *, const WinBitmapInfo *,
+                                                   uint32_t, uint32_t);
+    typedef int32_t(QCOSMO_MSABI *PeekMessageWFn)(NtMsg *, int64_t, uint32_t, uint32_t,
+                                                  uint32_t);
+    typedef bool32(QCOSMO_MSABI *InvalidateRectFn)(int64_t, const NtRect *, bool32);
+    typedef bool32(QCOSMO_MSABI *UpdateWindowFn)(int64_t);
+
+    int64_t m_hwnd = 0;
+    GetDCFn m_getDC = nullptr;
+    ReleaseDCFn m_releaseDC = nullptr;
+    StretchDIBitsFn m_stretchDIBits = nullptr;
+    PeekMessageWFn m_peekMessage = nullptr;
+    InvalidateRectFn m_invalidateRect = nullptr;
+    UpdateWindowFn m_updateWindow = nullptr;
+    QSize m_size;
+    Qt::MouseButtons m_buttons = Qt::NoButton;
+    std::deque<PendingEvent> m_pending;
+    QString m_error;
+};
+
+static QCosmoNativeWindowsHost *g_windowsHost = nullptr;
+
+static int64_t cosmoNativeWindowProc(int64_t hwnd, uint32_t message, uint64_t wParam,
+                                     int64_t lParam)
+{
+    if (g_windowsHost)
+        return g_windowsHost->wndProc(hwnd, message, wParam, lParam);
+    return DefWindowProc(hwnd, message, wParam, lParam);
+}
+
+bool QCosmoNativeWindowsHost::initialize(const QSize &size, const QString &title)
+{
+    int64_t user32 = LoadLibraryA("user32.dll");
+    int64_t gdi32 = LoadLibraryA("gdi32.dll");
+    if (!user32 || !gdi32) {
+        m_error = "failed to load user32.dll or gdi32.dll"_L1;
+        return false;
+    }
+
+    m_getDC = loadNtFunction<GetDCFn>(user32, "GetDC");
+    m_releaseDC = loadNtFunction<ReleaseDCFn>(user32, "ReleaseDC");
+    m_peekMessage = loadNtFunction<PeekMessageWFn>(user32, "PeekMessageW");
+    m_invalidateRect = loadNtFunction<InvalidateRectFn>(user32, "InvalidateRect");
+    m_updateWindow = loadNtFunction<UpdateWindowFn>(user32, "UpdateWindow");
+    m_stretchDIBits = loadNtFunction<StretchDIBitsFn>(gdi32, "StretchDIBits");
+    if (!m_getDC || !m_releaseDC || !m_peekMessage || !m_invalidateRect || !m_updateWindow
+        || !m_stretchDIBits)
+        return false;
+
+    g_windowsHost = this;
+
+    static const char16_t className[] = u"FiamyCosmoNativeWindow";
+    NtWndClass wc = {};
+    wc.style = kNtCsHredraw | kNtCsVredraw | kNtCsDblclks;
+    wc.lpfnWndProc = cosmoNativeWindowProc;
+    wc.lpszClassName = className;
+    RegisterClass(&wc);
+
+    const QString windowTitle = title.isEmpty() ? "Fiamy"_L1 : title;
+    const std::u16string wideTitle = windowTitle.toStdU16String();
+    const uint32_t style = kNtWsOverlappedwindow | kNtWsVisible;
+    m_hwnd = CreateWindowEx(0, className,
+                            reinterpret_cast<const char16_t *>(wideTitle.c_str()),
+                            style, kNtCwUsedefault,
+                            kNtCwUsedefault, size.width(), size.height(), 0, 0, 0, 0);
+    if (!m_hwnd) {
+        m_error = "CreateWindowEx failed"_L1;
+        g_windowsHost = nullptr;
+        return false;
+    }
+
+    ShowWindow(m_hwnd, kNtSwShow);
+    m_size = size;
+    return true;
+}
+
+void QCosmoNativeWindowsHost::shutdown()
+{
+    if (m_hwnd)
+        DestroyWindow(m_hwnd);
+    m_hwnd = 0;
+    if (g_windowsHost == this)
+        g_windowsHost = nullptr;
+}
+
+void QCosmoNativeWindowsHost::enqueueMouse(uint32_t message, int64_t lParam)
+{
+    const int x = int(int16_t(lParam & 0xffff));
+    const int y = int(int16_t((uint64_t(lParam) >> 16) & 0xffff));
+
+    PendingEvent event;
+    event.kind = PendingEvent::Mouse;
+    event.position = QPointF(x, y);
+
+    switch (message) {
+    case kNtWmLbuttondown:
+        m_buttons |= Qt::LeftButton;
+        event.changedButton = Qt::LeftButton;
+        event.eventType = QEvent::MouseButtonPress;
+        SetCapture(m_hwnd);
+        break;
+    case kNtWmLbuttonup:
+        m_buttons &= ~Qt::LeftButton;
+        event.changedButton = Qt::LeftButton;
+        event.eventType = QEvent::MouseButtonRelease;
+        ReleaseCapture();
+        break;
+    case kNtWmRbuttondown:
+        m_buttons |= Qt::RightButton;
+        event.changedButton = Qt::RightButton;
+        event.eventType = QEvent::MouseButtonPress;
+        SetCapture(m_hwnd);
+        break;
+    case kNtWmRbuttonup:
+        m_buttons &= ~Qt::RightButton;
+        event.changedButton = Qt::RightButton;
+        event.eventType = QEvent::MouseButtonRelease;
+        ReleaseCapture();
+        break;
+    case kNtWmMbuttondown:
+        m_buttons |= Qt::MiddleButton;
+        event.changedButton = Qt::MiddleButton;
+        event.eventType = QEvent::MouseButtonPress;
+        SetCapture(m_hwnd);
+        break;
+    case kNtWmMbuttonup:
+        m_buttons &= ~Qt::MiddleButton;
+        event.changedButton = Qt::MiddleButton;
+        event.eventType = QEvent::MouseButtonRelease;
+        ReleaseCapture();
+        break;
+    default:
+        event.changedButton = Qt::NoButton;
+        event.eventType = QEvent::MouseMove;
+        break;
+    }
+    event.buttons = m_buttons;
+    m_pending.push_back(event);
+}
+
+void QCosmoNativeWindowsHost::enqueueWheel(uint64_t wParam, int64_t lParam)
+{
+    PendingEvent event;
+    event.kind = PendingEvent::Wheel;
+    event.position = QPointF(int(int16_t(lParam & 0xffff)),
+                             int(int16_t((uint64_t(lParam) >> 16) & 0xffff)));
+    event.angleDelta = QPoint(0, int(int16_t((wParam >> 16) & 0xffff)));
+    m_pending.push_back(event);
+}
+
+void QCosmoNativeWindowsHost::enqueueKey(uint32_t message, uint64_t wParam)
+{
+    PendingEvent event;
+    event.kind = PendingEvent::Key;
+    event.eventType = message == kNtWmKeyup ? QEvent::KeyRelease : QEvent::KeyPress;
+    event.key = Qt::Key_unknown;
+    if (wParam >= 'A' && wParam <= 'Z')
+        event.key = Qt::Key_A + int(wParam - 'A');
+    else if (wParam >= '0' && wParam <= '9')
+        event.key = Qt::Key_0 + int(wParam - '0');
+    else if (wParam == 0x0d)
+        event.key = Qt::Key_Return;
+    else if (wParam == 0x1b)
+        event.key = Qt::Key_Escape;
+    else if (wParam == 0x08)
+        event.key = Qt::Key_Backspace;
+    else if (wParam == 0x20)
+        event.key = Qt::Key_Space;
+    if (event.key >= 0x20 && event.key <= 0x7e)
+        event.text = QString(QChar(ushort(event.key)));
+    m_pending.push_back(event);
+}
+
+void QCosmoNativeWindowsHost::enqueueResize(int64_t lParam)
+{
+    const int width = int(uint16_t(lParam & 0xffff));
+    const int height = int(uint16_t((uint64_t(lParam) >> 16) & 0xffff));
+    if (width <= 0 || height <= 0)
+        return;
+
+    PendingEvent event;
+    event.kind = PendingEvent::Resize;
+    event.size = QSize(width, height);
+    m_pending.push_back(event);
+    m_size = event.size;
+}
+
+int64_t QCosmoNativeWindowsHost::wndProc(int64_t hwnd, uint32_t message, uint64_t wParam,
+                                         int64_t lParam)
+{
+    switch (message) {
+    case kNtWmClose:
+    case kNtWmDestroy: {
+        PendingEvent event;
+        event.kind = PendingEvent::Close;
+        m_pending.push_back(event);
+        return 0;
+    }
+    case kNtWmLbuttondown:
+    case kNtWmLbuttonup:
+    case kNtWmRbuttondown:
+    case kNtWmRbuttonup:
+    case kNtWmMbuttondown:
+    case kNtWmMbuttonup:
+    case kNtWmMousemove:
+        enqueueMouse(message, lParam);
+        return 0;
+    case kNtWmMousewheel:
+        enqueueWheel(wParam, lParam);
+        return 0;
+    case kNtWmKeydown:
+    case kNtWmKeyup:
+        enqueueKey(message, wParam);
+        return 0;
+    case kNtWmSize:
+        enqueueResize(lParam);
+        return 0;
+    case kNtWmPaint: {
+        NtPaintStruct ps;
+        BeginPaint(hwnd, &ps);
+        EndPaint(hwnd, &ps);
+        return 0;
+    }
+    default:
+        return DefWindowProc(hwnd, message, wParam, lParam);
+    }
+}
+
+void QCosmoNativeWindowsHost::pumpEvents(QCosmoNativeEventSink *sink)
+{
+    if (!m_hwnd)
+        return;
+
+    NtMsg msg;
+    while (m_peekMessage(&msg, 0, 0, 0, 1)) {
+        TranslateMessage(&msg);
+        DispatchMessage(&msg);
+    }
+
+    while (!m_pending.empty()) {
+        const PendingEvent event = m_pending.front();
+        m_pending.pop_front();
+        if (!sink)
+            continue;
+        switch (event.kind) {
+        case PendingEvent::Close:
+            sink->handleHostClose();
+            break;
+        case PendingEvent::Mouse:
+            sink->handleHostMouse(event.position, event.buttons, event.changedButton,
+                                  event.eventType);
+            break;
+        case PendingEvent::Wheel:
+            sink->handleHostWheel(event.position, event.angleDelta);
+            break;
+        case PendingEvent::Key:
+            sink->handleHostKey(event.eventType, event.key, event.modifiers, event.text);
+            break;
+        case PendingEvent::Resize:
+            sink->handleHostResize(event.size);
+            break;
+        }
+    }
+}
+
+void QCosmoNativeWindowsHost::blit(const QImage &image, const QRegion &region)
+{
+    if (!m_hwnd || image.isNull())
+        return;
+
+    WinBitmapInfo bmi = {};
+    bmi.bmiHeader.biSize = sizeof(WinBitmapInfoHeader);
+    bmi.bmiHeader.biWidth = image.width();
+    bmi.bmiHeader.biHeight = -image.height();
+    bmi.bmiHeader.biPlanes = 1;
+    bmi.bmiHeader.biBitCount = 32;
+    bmi.bmiHeader.biCompression = 0; // BI_RGB
+
+    int64_t hdc = m_getDC(m_hwnd);
+    if (!hdc)
+        return;
+
+    for (const QRect &rect : region) {
+        m_stretchDIBits(hdc, rect.x(), rect.y(), rect.width(), rect.height(), rect.x(),
+                        image.height() - rect.y() - rect.height(), rect.width(), rect.height(),
+                        image.bits(), &bmi, 0, 0x00cc0020);
+    }
+    m_releaseDC(m_hwnd, hdc);
+    m_invalidateRect(m_hwnd, nullptr, false);
+    m_updateWindow(m_hwnd);
+}
+
+// -------------------------------------------------------------------------
+// Linux/X11 host. This speaks the small subset of the X11 wire protocol that
+// QFbScreen needs, avoiding libX11 because dlopen() is unavailable under APE.
+
+static quint16 x11Le16(const uchar *p)
+{
+    return quint16(p[0]) | (quint16(p[1]) << 8);
+}
+
+static qint16 x11LeS16(const uchar *p)
+{
+    return qint16(x11Le16(p));
+}
+
+static quint32 x11Le32(const uchar *p)
+{
+    return quint32(p[0]) | (quint32(p[1]) << 8) | (quint32(p[2]) << 16)
+            | (quint32(p[3]) << 24);
+}
+
+static quint16 x11Be16(const uchar *p)
+{
+    return (quint16(p[0]) << 8) | quint16(p[1]);
+}
+
+static int x11Pad4(int value)
+{
+    return (value + 3) & ~3;
+}
+
+static void x11Append8(QByteArray *buffer, quint8 value)
+{
+    buffer->append(char(value));
+}
+
+static void x11Append16(QByteArray *buffer, quint16 value)
+{
+    buffer->append(char(value & 0xff));
+    buffer->append(char((value >> 8) & 0xff));
+}
+
+static void x11AppendS16(QByteArray *buffer, qint16 value)
+{
+    x11Append16(buffer, quint16(value));
+}
+
+static void x11Append32(QByteArray *buffer, quint32 value)
+{
+    buffer->append(char(value & 0xff));
+    buffer->append(char((value >> 8) & 0xff));
+    buffer->append(char((value >> 16) & 0xff));
+    buffer->append(char((value >> 24) & 0xff));
+}
+
+static void x11AppendPadded(QByteArray *buffer, const QByteArray &data)
+{
+    buffer->append(data);
+    while (buffer->size() % 4)
+        buffer->append('\0');
+}
+
+static QByteArray x11DisplayNumber(const QByteArray &display)
+{
+    const int colon = display.indexOf(':');
+    if (colon < 0)
+        return "0";
+    int end = colon + 1;
+    while (end < display.size() && display.at(end) >= '0' && display.at(end) <= '9')
+        ++end;
+    QByteArray number = display.mid(colon + 1, end - colon - 1);
+    return number.isEmpty() ? QByteArray("0") : number;
+}
+
+struct X11AuthCookie {
+    QByteArray name;
+    QByteArray data;
+};
+
+static X11AuthCookie x11ReadAuthCookie(const QByteArray &display)
+{
+    X11AuthCookie cookie;
+    QByteArray path = qgetenv("XAUTHORITY");
+    if (path.isEmpty()) {
+        const QByteArray home = qgetenv("HOME");
+        if (!home.isEmpty())
+            path = home + "/.Xauthority";
+    }
+    if (path.isEmpty())
+        return cookie;
+
+    QFile file(QString::fromLocal8Bit(path));
+    if (!file.open(QIODevice::ReadOnly))
+        return cookie;
+
+    const QByteArray bytes = file.readAll();
+    const QByteArray displayNo = x11DisplayNumber(display);
+    const uchar *p = reinterpret_cast<const uchar *>(bytes.constData());
+    const uchar *end = p + bytes.size();
+    X11AuthCookie firstMitCookie;
+    while (end - p >= 2) {
+        const quint16 family = x11Be16(p);
+        Q_UNUSED(family);
+        p += 2;
+        if (end - p < 2)
+            break;
+        const quint16 addressLen = x11Be16(p);
+        p += 2;
+        if (end - p < addressLen + 2)
+            break;
+        p += addressLen;
+        const quint16 numberLen = x11Be16(p);
+        p += 2;
+        if (end - p < numberLen + 2)
+            break;
+        const QByteArray number(reinterpret_cast<const char *>(p), numberLen);
+        p += numberLen;
+        const quint16 nameLen = x11Be16(p);
+        p += 2;
+        if (end - p < nameLen + 2)
+            break;
+        const QByteArray name(reinterpret_cast<const char *>(p), nameLen);
+        p += nameLen;
+        const quint16 dataLen = x11Be16(p);
+        p += 2;
+        if (end - p < dataLen)
+            break;
+        const QByteArray data(reinterpret_cast<const char *>(p), dataLen);
+        p += dataLen;
+
+        if (name != "MIT-MAGIC-COOKIE-1")
+            continue;
+        if (firstMitCookie.name.isEmpty())
+            firstMitCookie = { name, data };
+        if (number == displayNo)
+            return { name, data };
+    }
+    return firstMitCookie;
+}
