diff --git a/src/plugins/platforms/cosmonative/qcosmonativescreen.cpp b/src/plugins/platforms/cosmonative/qcosmonativescreen.cpp
new file mode 100644
index 00000000000..c5306431e4b
--- /dev/null
+++ b/src/plugins/platforms/cosmonative/qcosmonativescreen.cpp
@@ -0,0 +1,174 @@
+// Copyright (C) 2026
+// SPDX-License-Identifier: LicenseRef-Qt-Commercial OR LGPL-3.0-only OR GPL-2.0-only OR GPL-3.0-only
+
+#include "qcosmonativescreen.h"
+
+#include <QtCore/QCoreApplication>
+#include <QtCore/QRegularExpression>
+#include <QtFbSupport/private/qfbcursor_p.h>
+#include <QtFbSupport/private/qfbwindow_p.h>
+#include <QtGui/QWindow>
+#include <qpa/qwindowsysteminterface.h>
+
+QT_BEGIN_NAMESPACE
+
+using namespace Qt::StringLiterals;
+
+QCosmoNativeScreen::QCosmoNativeScreen(const QStringList &args)
+    : m_args(args)
+{
+}
+
+QCosmoNativeScreen::~QCosmoNativeScreen()
+{
+    if (m_host)
+        m_host->shutdown();
+}
+
+bool QCosmoNativeScreen::initialize()
+{
+    QRegularExpression sizeRx("size=(\\d+)x(\\d+)"_L1);
+    QRegularExpression mmSizeRx("mmsize=(?<width>(\\d*\\.)?\\d+)x(?<height>(\\d*\\.)?\\d+)"_L1);
+
+    mGeometry = QRect(0, 0, 1024, 768);
+    mFormat = QImage::Format_ARGB32_Premultiplied;
+    mDepth = 32;
+    mPhysicalSize = QSizeF(mGeometry.width() / 96. * 25.4, mGeometry.height() / 96. * 25.4);
+
+    for (const QString &arg : std::as_const(m_args)) {
+        QRegularExpressionMatch match;
+        if (arg.contains(sizeRx, &match)) {
+            mGeometry.setSize(QSize(match.captured(1).toInt(), match.captured(2).toInt()));
+        } else if (arg.contains(mmSizeRx, &match)) {
+            mPhysicalSize = QSizeF(match.captured("width").toDouble(),
+                                   match.captured("height").toDouble());
+        }
+    }
+
+    m_host.reset(QCosmoNativeHost::create());
+    if (!m_host) {
+        qWarning("cosmonative: no native host is available on this OS");
+        return false;
+    }
+
+    if (!m_host->initialize(mGeometry.size(), "Fiamy"_L1)) {
+        qWarning("cosmonative: failed to initialize native host: %s",
+                 qPrintable(m_host->errorString()));
+        return false;
+    }
+
+    QFbScreen::initializeCompositor();
+
+#if QT_CONFIG(cursor)
+    mCursor = new QFbCursor(this);
+#endif
+
+    m_pumpTimer.reset(new QTimer(this));
+    QObject::connect(m_pumpTimer.data(), &QTimer::timeout, this, [this]() {
+        if (m_host)
+            m_host->pumpEvents(this);
+    });
+    m_pumpTimer->start(8);
+
+    return true;
+}
+
+QRegion QCosmoNativeScreen::doRedraw()
+{
+    const QRegion touched = QFbScreen::doRedraw();
+    if (!touched.isEmpty() && m_host)
+        m_host->blit(mScreenImage, touched);
+    return touched;
+}
+
+QPixmap QCosmoNativeScreen::grabWindow(WId wid, int x, int y, int width, int height) const
+{
+    if (!wid) {
+        if (width < 0)
+            width = mScreenImage.width() - x;
+        if (height < 0)
+            height = mScreenImage.height() - y;
+        return QPixmap::fromImage(mScreenImage).copy(x, y, width, height);
+    }
+
+    QFbWindow *window = windowForId(wid);
+    if (window) {
+        const QRect geom = window->geometry();
+        if (width < 0)
+            width = geom.width() - x;
+        if (height < 0)
+            height = geom.height() - y;
+        QRect rect(geom.topLeft() + QPoint(x, y), QSize(width, height));
+        rect &= window->geometry();
+        return QPixmap::fromImage(mScreenImage).copy(rect);
+    }
+
+    return QPixmap();
+}
+
+QFbScreen::Flags QCosmoNativeScreen::flags() const
+{
+    return QFbScreen::DontForceFirstWindowToFullScreen;
+}
+
+QPointF QCosmoNativeScreen::localPositionForWindow(QWindow *window,
+                                                  const QPointF &screenPosition) const
+{
+    if (!window)
+        return screenPosition;
+    return screenPosition - QPointF(window->geometry().topLeft());
+}
+
+void QCosmoNativeScreen::handleHostClose()
+{
+    QCoreApplication::quit();
+}
+
+void QCosmoNativeScreen::handleHostMouse(const QPointF &position, Qt::MouseButtons buttons,
+                                         Qt::MouseButton changedButton, QEvent::Type type)
+{
+    m_buttons = buttons;
+
+    QWindow *window = topLevelAt(position.toPoint());
+    if (!window)
+        window = topWindow();
+
+    const QPointF local = localPositionForWindow(window, position);
+    QWindowSystemInterface::handleMouseEvent(window, local, position, buttons, changedButton,
+                                             type, Qt::NoModifier);
+}
+
+void QCosmoNativeScreen::handleHostWheel(const QPointF &position, const QPoint &angleDelta)
+{
+    QWindow *window = topLevelAt(position.toPoint());
+    if (!window)
+        window = topWindow();
+
+    const QPointF local = localPositionForWindow(window, position);
+    QWindowSystemInterface::handleWheelEvent(window, local, position, QPoint(), angleDelta,
+                                             Qt::NoModifier);
+}
+
+void QCosmoNativeScreen::handleHostKey(QEvent::Type type, int key,
+                                       Qt::KeyboardModifiers modifiers, const QString &text)
+{
+    QWindow *window = topWindow();
+    QWindowSystemInterface::handleKeyEvent(window, type, key, modifiers, text);
+}
+
+void QCosmoNativeScreen::handleHostResize(const QSize &size)
+{
+    if (!size.isValid() || size.isEmpty() || size == mGeometry.size())
+        return;
+
+    setGeometry(QRect(mGeometry.topLeft(), size));
+
+    if (QWindow *window = topWindow()) {
+        const QRect windowGeometry(window->position(), size);
+        if (window->handle())
+            window->handle()->setGeometry(windowGeometry);
+        QWindowSystemInterface::handleExposeEvent(window, QRect(QPoint(0, 0), size));
+    }
+}
+
+QT_END_NAMESPACE
