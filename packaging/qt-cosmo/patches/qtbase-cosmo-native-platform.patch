+                "hasAlpha:isPlanar:colorSpaceName:bitmapFormat:bytesPerRow:bitsPerPixel:"),
+            planes, width, height, 8, 4, true, false, string("NSDeviceRGBColorSpace"),
+            alphaFirst | littleEndian32, bytesPerLine, 32);
+}
