+
+QCosmoNativeIntegration::QCosmoNativeIntegration(const QStringList &paramList)
+    : m_primaryScreen(new QCosmoNativeScreen(paramList)),
+      m_fontDb(new QGenericUnixFontDatabase)
+{
+}
+
+QCosmoNativeIntegration::~QCosmoNativeIntegration()
+{
+    QWindowSystemInterface::handleScreenRemoved(m_primaryScreen);
+}
+
+void QCosmoNativeIntegration::initialize()
+{
+    if (m_primaryScreen->initialize())
+        QWindowSystemInterface::handleScreenAdded(m_primaryScreen);
+    else
+        qWarning("cosmonative: Failed to initialize screen");
+
+    m_inputContext = QPlatformInputContextFactory::create();
+    m_nativeInterface.reset(new QPlatformNativeInterface);
+
+    QInputDeviceManagerPrivate::get(QGuiApplicationPrivate::inputDeviceManager())->setDeviceCount(
+            QInputDeviceManager::DeviceTypePointer, 1);
+    QInputDeviceManagerPrivate::get(QGuiApplicationPrivate::inputDeviceManager())->setDeviceCount(
+            QInputDeviceManager::DeviceTypeKeyboard, 1);
+}
+
+bool QCosmoNativeIntegration::hasCapability(QPlatformIntegration::Capability cap) const
+{
+    switch (cap) {
+    case ThreadedPixmaps:
+        return true;
+    case WindowManagement:
+        return false;
+    case RhiBasedRendering:
+        return false;
+    default:
+        return QPlatformIntegration::hasCapability(cap);
+    }
+}
+
+QPlatformBackingStore *QCosmoNativeIntegration::createPlatformBackingStore(QWindow *window) const
+{
+    return new QFbBackingStore(window);
+}
+
+QPlatformWindow *QCosmoNativeIntegration::createPlatformWindow(QWindow *window) const
+{
+    return new QFbWindow(window);
+}
+
+QAbstractEventDispatcher *QCosmoNativeIntegration::createEventDispatcher() const
+{
+    return createUnixEventDispatcher();
+}
+
+QList<QPlatformScreen *> QCosmoNativeIntegration::screens() const
+{
+    return { m_primaryScreen };
+}
+
+QPlatformFontDatabase *QCosmoNativeIntegration::fontDatabase() const
+{
+    return m_fontDb.data();
+}
+
+QPlatformServices *QCosmoNativeIntegration::services() const
+{
+    if (m_services.isNull())
+        m_services.reset(new QDesktopUnixServices);
+
+    return m_services.data();
+}
+
+QPlatformNativeInterface *QCosmoNativeIntegration::nativeInterface() const
+{
+    return m_nativeInterface.data();
+}
+
+QT_END_NAMESPACE
