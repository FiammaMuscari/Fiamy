+
+#include <QtFbSupport/private/qfbbackingstore_p.h>
+#include <QtFbSupport/private/qfbwindow_p.h>
+#include <QtGui/private/qdesktopunixservices_p.h>
+#include <QtGui/private/qgenericunixeventdispatcher_p.h>
