+namespace QCosmoAudio {
+
+QList<QAudioDevice> QCosmoAudioDevices::findAudioOutputs() const
+{
+    auto devicePrivate = std::make_unique<QAudioDevicePrivate>(
+            QByteArrayLiteral("cosmoaudio:default"), QAudioDevice::Output,
+            QStringLiteral("Cosmopolitan Audio"));
+
+    devicePrivate->isDefault = true;
+    devicePrivate->minimumSampleRate = 8000;
+    devicePrivate->maximumSampleRate = 192000;
+    devicePrivate->minimumChannelCount = 1;
+    devicePrivate->maximumChannelCount = 2;
+    devicePrivate->supportedSampleFormats = qAllSupportedSampleFormats();
+    devicePrivate->channelConfiguration = QAudioFormat::ChannelConfigStereo;
+
+    QAudioFormat preferred;
+    preferred.setSampleRate(44100);
+    preferred.setChannelCount(2);
+    preferred.setSampleFormat(QAudioFormat::Float);
+    devicePrivate->preferredFormat = preferred;
+
+    return { QAudioDevicePrivate::createQAudioDevice(std::move(devicePrivate)) };
+}
+
+QPlatformAudioSink *QCosmoAudioDevices::createAudioSink(const QAudioDevice &device,
+                                                        const QAudioFormat &format,
+                                                        QObject *parent)
+{
+    return new QCosmoAudioSink(device, format, parent);
+}
+
+} // namespace QCosmoAudio
+
+QT_END_NAMESPACE
