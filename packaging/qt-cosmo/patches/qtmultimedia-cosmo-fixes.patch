+static void traceCosmoAudioFrame(const Frame &frame, const QAudioBuffer &buffer,
+                                 int &traceFramesLogged)
+{
+#ifdef __COSMOPOLITAN__
+    if (!qEnvironmentVariableIsSet("FIAMY_AUDIO_TRACE_FRAMES") || traceFramesLogged >= 90)
+        return;
+
+    ++traceFramesLogged;
+
+    int firstNonZeroSample = -1;
+    int maxAbs = 0;
+    quint32 hash = 2166136261u;
+    if (buffer.format().sampleFormat() == QAudioFormat::Int16) {
+        const auto *samples = buffer.constData<int16_t>();
+        const int sampleCount = buffer.sampleCount();
+        for (int i = 0; i < sampleCount; ++i) {
+            const int value = samples[i];
+            const int absValue = qAbs(value);
+            if (firstNonZeroSample < 0 && absValue > 1)
+                firstNonZeroSample = i;
+            maxAbs = qMax(maxAbs, absValue);
+            hash ^= quint16(value);
+            hash *= 16777619u;
+        }
+    }
+
+    qDebug() << "AudioRenderer frame"
+             << "n=" << traceFramesLogged
+             << "ptsUs=" << frame.absolutePts().get()
+             << "durationUs=" << frame.duration().get()
+             << "frames=" << buffer.frameCount()
+             << "bytes=" << buffer.byteCount()
+             << "firstNonZeroSample=" << firstNonZeroSample
+             << "maxAbs=" << maxAbs
+             << "hash=" << Qt::hex << hash << Qt::dec;
+#else
+    Q_UNUSED(frame);
+    Q_UNUSED(buffer);
+    Q_UNUSED(traceFramesLogged);
+#endif
+}
