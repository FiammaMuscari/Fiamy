index 000000000..dff7d0930
--- /dev/null
+++ b/src/multimedia/cosmoaudio/qcosmoaudiosink.cpp
@@ -0,0 +1,466 @@
+// Copyright (C) 2026
+// SPDX-License-Identifier: LicenseRef-Qt-Commercial OR LGPL-3.0-only OR GPL-2.0-only OR GPL-3.0-only
+
+#include "qcosmoaudiosink_p.h"
+
+#include <QtCore/qdebug.h>
+#include <QtCore/qspan.h>
+#include <QtMultimedia/private/qaudiohelpers_p.h>
+
+#include <algorithm>
+#include <atomic>
+#include <chrono>
+#include <cosmoaudio.h>
+#include <libc/dce.h>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <string>
+
+using QCosmoAudioOutputTapCallback = void (*)(const float *samples, int frames, int channels,
+                                              int sampleRate, void *userData);
+
+namespace {
+
+std::atomic<QCosmoAudioOutputTapCallback> g_outputTapCallback = nullptr;
+std::atomic<void *> g_outputTapUserData = nullptr;
+
+struct AudioDump
+{
+    FILE *file = nullptr;
+    std::string path;
+    int sampleRate = 0;
+    int channels = 0;
+    uint32_t framesWritten = 0;
+    uint32_t maxFrames = 0;
+    bool initialized = false;
+    bool finished = false;
+
+    void writeSamples(const float *samples, int frames, int channelCount, int rate)
+    {
+        if (finished)
+            return;
+
+        if (!initialized)
+            initialize(channelCount, rate);
+
+        if (!file || frames <= 0 || channelCount <= 0)
+            return;
+
+        const uint32_t remaining = maxFrames > framesWritten ? maxFrames - framesWritten : 0;
+        const uint32_t framesToWrite = std::min<uint32_t>(remaining, uint32_t(frames));
+        if (framesToWrite == 0) {
+            finish();
+            return;
+        }
+
+        for (uint32_t frame = 0; frame < framesToWrite; ++frame) {
+            for (int channel = 0; channel < channels; ++channel) {
+                const int sourceChannel = std::min(channel, channelCount - 1);
+                const float clamped =
+                        std::clamp(samples[qsizetype(frame) * channelCount + sourceChannel],
+                                   -1.0f, 1.0f);
+                const int16_t sample = clamped < 0.0f
+                        ? int16_t(clamped * 32768.0f)
+                        : int16_t(clamped * 32767.0f);
+                fwrite(&sample, sizeof(sample), 1, file);
+            }
+        }
+
+        framesWritten += framesToWrite;
+        if (framesWritten >= maxFrames)
+            finish();
+    }
+
+private:
+    static void writeU16(FILE *out, uint16_t value)
+    {
+        fwrite(&value, sizeof(value), 1, out);
+    }
+
+    static void writeU32(FILE *out, uint32_t value)
+    {
+        fwrite(&value, sizeof(value), 1, out);
+    }
+
+    void writeHeader(uint32_t dataBytes)
+    {
+        if (!file)
+            return;
+
+        const uint32_t byteRate = uint32_t(sampleRate * channels * int(sizeof(int16_t)));
+        const uint16_t blockAlign = uint16_t(channels * int(sizeof(int16_t)));
+
+        fseek(file, 0, SEEK_SET);
+        fwrite("RIFF", 1, 4, file);
+        writeU32(file, 36 + dataBytes);
+        fwrite("WAVE", 1, 4, file);
+        fwrite("fmt ", 1, 4, file);
+        writeU32(file, 16);
+        writeU16(file, 1);
+        writeU16(file, uint16_t(channels));
+        writeU32(file, uint32_t(sampleRate));
+        writeU32(file, byteRate);
+        writeU16(file, blockAlign);
+        writeU16(file, 16);
+        fwrite("data", 1, 4, file);
+        writeU32(file, dataBytes);
+        fseek(file, 0, SEEK_END);
+    }
+
+    void initialize(int channelCount, int rate)
+    {
+        initialized = true;
+
+        const char *dumpPath = getenv("FIAMY_AUDIO_DUMP_PATH");
+        if (!dumpPath || !*dumpPath) {
+            finished = true;
+            return;
+        }
+
+        const char *secondsEnv = getenv("FIAMY_AUDIO_DUMP_SECONDS");
+        char *end = nullptr;
+        long seconds = secondsEnv && *secondsEnv ? strtol(secondsEnv, &end, 10) : 10;
+        if (seconds <= 0 || seconds > 120 || (end && *end))
+            seconds = 10;
+
+        sampleRate = rate > 0 ? rate : 44100;
+        channels = std::clamp(channelCount, 1, 2);
+        maxFrames = uint32_t(std::min<long>(seconds * long(sampleRate), UINT32_MAX));
+        path = dumpPath;
+
+        file = fopen(path.c_str(), "wb");
+        if (!file) {
+            qWarning() << "QCosmoAudioSink: failed to open audio dump" << path.c_str();
+            finished = true;
+            return;
+        }
+
+        writeHeader(0);
+        qDebug() << "QCosmoAudioSink: writing audio dump" << path.c_str()
+                 << "seconds=" << seconds
+                 << "sampleRate=" << sampleRate
+                 << "channels=" << channels;
+    }
+
+    void finish()
+    {
+        if (!file) {
+            finished = true;
+            return;
+        }
+
+        const uint32_t dataBytes = framesWritten * uint32_t(channels) * uint32_t(sizeof(int16_t));
+        writeHeader(dataBytes);
+        fclose(file);
+        file = nullptr;
+        finished = true;
+        qDebug() << "QCosmoAudioSink: finished audio dump" << path.c_str()
+                 << "frames=" << framesWritten;
+    }
+};
+
+AudioDump &audioDump()
+{
+    static AudioDump dump;
+    return dump;
+}
+
+} // namespace
+
+extern "C" void qcosmoaudio_set_output_tap(QCosmoAudioOutputTapCallback callback, void *userData)
+{
+    g_outputTapUserData.store(userData, std::memory_order_release);
+    g_outputTapCallback.store(callback, std::memory_order_release);
+}
+
+QT_BEGIN_NAMESPACE
+
+namespace QCosmoAudio {
+
+namespace {
+
+constexpr int defaultPeriodFrames = 1024;
+constexpr int defaultXnuPeriodFrames = 8192;
+constexpr int minPeriodFrames = 256;
+constexpr int maxPeriodFrames = 8192;
+
+QSpan<std::byte> bytesForFloats(std::vector<float> &buffer, qsizetype samples)
+{
+    return { reinterpret_cast<std::byte *>(buffer.data()), samples * qsizetype(sizeof(float)) };
+}
+
+} // namespace
+
+QCosmoAudioSinkStream::QCosmoAudioSinkStream(QAudioDevice device, const QAudioFormat &format,
+                                             std::optional<qsizetype> ringbufferSize,
+                                             QCosmoAudioSink *parent, float volume,
+                                             std::optional<int32_t> hardwareBufferSize,
+                                             AudioEndpointRole)
+    : QPlatformAudioSinkStream(std::move(device), format, ringbufferSize, hardwareBufferSize,
+                               volume),
+      m_parent(parent)
+{
+    m_channels = std::clamp(format.channelCount(), 1, 2);
+    const int fallbackPeriodFrames = IsXnu() ? defaultXnuPeriodFrames : defaultPeriodFrames;
+    m_periodFrames = std::clamp(hardwareBufferSize.value_or(fallbackPeriodFrames), minPeriodFrames,
+                                maxPeriodFrames);
+}
+
+QCosmoAudioSinkStream::~QCosmoAudioSinkStream()
+{
+    stop(ShutdownPolicy::DiscardRingbuffer);
+}
+
+bool QCosmoAudioSinkStream::open()
+{
+    if (m_audio)
+        return true;
+
+    CosmoAudioOpenOptions options;
+    std::memset(&options, 0, sizeof(options));
+    options.sizeofThis = sizeof(options);
+    options.deviceType = kCosmoAudioDeviceTypePlayback;
+    options.sampleRate = m_format.sampleRate() > 0 ? m_format.sampleRate() : 44100;
+    options.channels = m_channels;
+    options.bufferFrames = IsXnu()
+            ? std::max(m_periodFrames * 4, options.sampleRate / 2)
+            : std::max(m_periodFrames * 4, 1024);
+    options.debugLog = 0;
+
+    const int status = cosmoaudio_open(&m_audio, &options);
+    if (status != COSMOAUDIO_SUCCESS) {
+        qWarning() << "QCosmoAudioSink: cosmoaudio_open failed:" << status;
+        m_audio = nullptr;
+        return false;
+    }
+
+    m_outputBuffer.resize(qsizetype(m_periodFrames) * m_channels);
+    m_sampleRate = m_format.sampleRate() > 0 ? m_format.sampleRate() : options.sampleRate;
+    m_prefillFramesRemaining = IsXnu() ? std::max(m_periodFrames * 2, m_sampleRate / 4) : 0;
+    return true;
+}
+
+bool QCosmoAudioSinkStream::start(QIODevice *device)
+{
+    Q_ASSERT(thread()->isCurrentThread());
+    setQIODevice(device);
+    pullFromQIODevice();
+    createQIODeviceConnections(device);
+    return startWorker();
+}
+
+bool QCosmoAudioSinkStream::start(AudioCallback &&callback)
+{
+    Q_ASSERT(thread()->isCurrentThread());
+    m_audioCallback = std::move(callback);
+    return startWorker();
+}
+
+QIODevice *QCosmoAudioSinkStream::start()
+{
+    auto *writer = createRingbufferWriterDevice();
+    setIdleState(true);
+    return start(writer) ? writer : nullptr;
+}
+
+bool QCosmoAudioSinkStream::startWorker()
+{
+    if (!m_audio || m_worker.joinable())
+        return false;
+
+    m_nextWriteTime = std::chrono::steady_clock::now();
+    m_worker = std::thread([this] {
+        workerLoop();
+    });
+    return true;
+}
+
+void QCosmoAudioSinkStream::stop(ShutdownPolicy policy)
+{
+    requestStop();
+    disconnectQIODeviceConnections();
+
+    if (m_worker.joinable())
+        m_worker.join();
+
+    if (policy == ShutdownPolicy::DrainRingbuffer && m_audio)
+        cosmoaudio_flush(m_audio);
+
+    closeAudio();
+}
+
+void QCosmoAudioSinkStream::suspend()
+{
+    m_suspended.store(true, std::memory_order_release);
+}
+
+void QCosmoAudioSinkStream::resume()
+{
+    m_suspended.store(false, std::memory_order_release);
+}
+
+void QCosmoAudioSinkStream::updateStreamIdle(bool idle)
+{
+    if (m_parent)
+        m_parent->updateStreamIdle(idle);
+}
+
+void QCosmoAudioSinkStream::workerLoop()
+{
+    using namespace std::chrono_literals;
+
+    while (!isStopRequested(std::memory_order_acquire)) {
+        if (m_suspended.load(std::memory_order_acquire)) {
+            std::this_thread::sleep_for(10ms);
+            continue;
+        }
+
+        int writeFrames = m_periodFrames;
+        const int pollStatus = cosmoaudio_poll(m_audio, nullptr, &writeFrames);
+        if (pollStatus != COSMOAUDIO_SUCCESS) {
+            reportIOError();
+            return;
+        }
+
+        int frames = std::clamp(writeFrames, 0, m_periodFrames);
+        if (!m_audioCallback) {
+            const int readableFrames = ringbufferReadableFrames();
+            if (readableFrames <= 0) {
+                std::this_thread::sleep_for(1ms);
+                continue;
+            }
+            frames = std::min(frames, readableFrames);
+        }
+        if (frames <= 0) {
+            std::this_thread::sleep_for(IsXnu() ? 2ms : 1ms);
+            continue;
+        }
+
+        const bool ok = m_audioCallback ? fillFromCallback(frames) : fillFromRingbuffer(frames);
+        if (!ok) {
+            reportIOError();
+            return;
+        }
+
+        notifyOutputTap(frames);
+
+        const int writeStatus = cosmoaudio_write(m_audio, m_outputBuffer.data(), frames);
+        if (writeStatus < 0) {
+            reportIOError();
+            return;
+        }
+
+        paceOutput(frames);
+    }
+}
+
+int QCosmoAudioSinkStream::ringbufferReadableFrames()
+{
+    const int samples = visitRingbuffer([](auto &ringbuffer) {
+        return ringbuffer.used();
+    });
+    return m_channels > 0 ? samples / m_channels : 0;
+}
+
+void QCosmoAudioSinkStream::paceOutput(int frames)
+{
+    if (!IsXnu() || m_sampleRate <= 0)
+        return;
+
+    const auto now = std::chrono::steady_clock::now();
+    const auto frameDuration = std::chrono::duration_cast<std::chrono::steady_clock::duration>(
+            std::chrono::duration<double>(double(frames) / double(m_sampleRate)));
+
+    if (m_prefillFramesRemaining > 0) {
+        m_prefillFramesRemaining -= frames;
+        m_nextWriteTime += frameDuration;
+        return;
+    }
+
+    if (m_nextWriteTime > now)
+        std::this_thread::sleep_until(m_nextWriteTime);
+
+    const auto nextFrameTime = std::chrono::steady_clock::now();
+    m_nextWriteTime = std::max(m_nextWriteTime, nextFrameTime) + frameDuration;
+}
+
+void QCosmoAudioSinkStream::notifyOutputTap(int frames)
+{
+    audioDump().writeSamples(m_outputBuffer.data(), frames, m_channels, m_sampleRate);
+
+    const auto callback = g_outputTapCallback.load(std::memory_order_acquire);
+    if (!callback)
+        return;
+
+    callback(m_outputBuffer.data(), frames, m_channels, m_sampleRate,
+             g_outputTapUserData.load(std::memory_order_acquire));
+}
+
+bool QCosmoAudioSinkStream::fillFromRingbuffer(int frames)
+{
+    const qsizetype samples = qsizetype(frames) * m_channels;
+    std::fill_n(m_outputBuffer.data(), samples, 0.0f);
+    const uint64_t consumedFrames =
+            QPlatformAudioSinkStream::process(bytesForFloats(m_outputBuffer, samples), frames,
+                                              NativeSampleFormat::float32_t);
+    if (consumedFrames < uint64_t(frames)) {
+        const uint64_t missingFrames = uint64_t(frames) - consumedFrames;
+        m_shortReadCount++;
+        m_shortReadFrames += missingFrames;
+
+        const auto now = std::chrono::steady_clock::now();
+        if (m_lastShortReadLog.time_since_epoch().count() == 0
+            || now - m_lastShortReadLog > std::chrono::seconds(2)) {
+            qWarning() << "QCosmoAudioSink: output underrun"
+                       << "missingFrames=" << missingFrames
+                       << "totalUnderruns=" << m_shortReadCount
+                       << "totalMissingFrames=" << m_shortReadFrames;
+            m_lastShortReadLog = now;
+        }
+    }
+    return true;
+}
+
+bool QCosmoAudioSinkStream::fillFromCallback(int frames)
+{
+    const qsizetype byteCount = m_format.bytesForFrames(frames);
+    m_callbackBuffer.resize(byteCount);
+    auto callbackBytes =
+            QSpan<std::byte>(reinterpret_cast<std::byte *>(m_callbackBuffer.data()), byteCount);
+
+    QtMultimediaPrivate::runAudioCallback(*m_audioCallback, callbackBytes, m_format, volume());
+
+    const qsizetype samples = qsizetype(frames) * m_channels;
+    std::fill_n(m_outputBuffer.data(), samples, 0.0f);
+    QAudioHelperInternal::convertSampleFormat(
+            callbackBytes, QAudioHelperInternal::toNativeSampleFormat(m_format.sampleFormat()),
+            bytesForFloats(m_outputBuffer, samples), NativeSampleFormat::float32_t);
+    return true;
+}
+
+void QCosmoAudioSinkStream::reportIOError()
+{
+    requestStop();
+    invokeOnAppThread([this] {
+        handleIOError(m_parent);
+    });
+}
+
+void QCosmoAudioSinkStream::closeAudio()
+{
+    if (!m_audio)
+        return;
+
+    cosmoaudio_close(m_audio);
+    m_audio = nullptr;
+}
